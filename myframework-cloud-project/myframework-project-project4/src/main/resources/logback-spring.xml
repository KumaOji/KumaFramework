<?xml version="1.0" encoding="UTF-8"?>
<configuration>
    <include resource="org/springframework/boot/logging/logback/defaults.xml"/>

    <!-- 定义日志文件存储路径 -->
    <property name="LOG_HOME" value="${LOG_PATH:-./logs}"/>
    <property name="APP_NAME" value="${APP_NAME:-app}"/>

    <!-- 控制台输出 -->
    <appender name="CONSOLE" class="ch.qos.logback.core.ConsoleAppender">
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <!-- 控制台只显示 INFO 及以上级别，减少启动时的日志输出 -->
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>INFO</level>
        </filter>
    </appender>

    <!-- 启动日志 - 单独输出 -->
    <appender name="STARTUP_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-startup.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-startup.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>3GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>WARN</level>
        </filter>
    </appender>

    <!-- 应用日志文件 -->
    <appender name="FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>30</maxHistory>
            <totalSizeCap>10GB</totalSizeCap>
        </rollingPolicy>
    </appender>

    <!-- 错误日志单独输出 -->
    <appender name="ERROR_FILE" class="ch.qos.logback.core.rolling.RollingFileAppender">
        <file>${LOG_HOME}/${APP_NAME}-error.log</file>
        <encoder>
            <pattern>%d{yyyy-MM-dd HH:mm:ss.SSS} [%thread] %-5level %logger{50} - %msg%n</pattern>
            <charset>UTF-8</charset>
        </encoder>
        <rollingPolicy class="ch.qos.logback.core.rolling.SizeAndTimeBasedRollingPolicy">
            <fileNamePattern>${LOG_HOME}/${APP_NAME}-error.%d{yyyy-MM-dd}.%i.log</fileNamePattern>
            <maxFileSize>100MB</maxFileSize>
            <maxHistory>60</maxHistory>
            <totalSizeCap>5GB</totalSizeCap>
        </rollingPolicy>
        <filter class="ch.qos.logback.classic.filter.ThresholdFilter">
            <level>ERROR</level>
        </filter>
    </appender>

    <!-- 启动相关日志级别 - 减少启动时日志输出 -->
    <logger name="org.springframework.boot" level="WARN" additivity="false">
        <appender-ref ref="STARTUP_FILE"/>
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <logger name="org.springframework.context" level="WARN" additivity="false">
        <appender-ref ref="STARTUP_FILE"/>
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- 组件扫描相关日志 - 减少输出 -->
    <logger name="org.springframework.context.annotation" level="WARN"/>
    <logger name="org.springframework.beans.factory" level="WARN" additivity="false">
        <appender-ref ref="STARTUP_FILE"/>
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- Bean 创建相关日志 - 减少输出 -->
    <logger name="org.springframework.beans" level="WARN"/>

    <logger name="org.springframework.boot.web.embedded" level="WARN" additivity="false">
        <appender-ref ref="STARTUP_FILE"/>
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <logger name="org.springframework.boot.autoconfigure" level="WARN" additivity="false">
        <appender-ref ref="STARTUP_FILE"/>
        <appender-ref ref="CONSOLE"/>
        <appender-ref ref="FILE"/>
    </logger>

    <!-- MyBatis 相关日志 - 减少启动时输出 -->
    <logger name="org.apache.ibatis" level="WARN"/>
    <logger name="org.mybatis" level="WARN"/>

    <!-- HikariCP 相关日志 - 减少启动时输出 -->
    <logger name="com.zaxxer.hikari" level="WARN"/>

    <!-- Undertow 相关日志 - 减少启动时输出 -->
    <logger name="io.undertow" level="WARN"/>

    <!-- XNIO 相关日志 - 过滤关闭时的异常（应用关闭时的 XNIO 错误可以忽略） -->
    <logger name="org.xnio" level="ERROR" additivity="false">
        <appender-ref ref="FILE"/>
        <!-- 不输出到控制台和错误日志，避免关闭时的错误日志 -->
    </logger>
    <logger name="org.xnio.listener" level="ERROR" additivity="false">
        <appender-ref ref="FILE"/>
        <!-- 不输出到控制台和错误日志，避免关闭时的错误日志 -->
    </logger>

    <!-- Quartz 相关日志 - 减少启动时输出 -->
    <logger name="org.quartz" level="WARN"/>

    <!-- 开发环境配置 -->
    <springProfile name="dev">
        <!-- 开发环境：减少 Spring 框架的详细日志，只保留关键信息 -->
        <logger name="org.springframework.boot" level="INFO"/>
        <logger name="org.springframework.context" level="INFO"/>
        <logger name="org.springframework.beans" level="WARN"/>

        <!-- 应用包日志保持 DEBUG，便于调试业务代码 -->
        <logger name="cn.kuma.blog" level="DEBUG"/>

        <!-- 根日志级别：INFO，减少不必要的 DEBUG 日志 -->
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- 生产环境配置 -->
    <springProfile name="prod">
        <!-- 生产环境减少启动日志 -->
        <logger name="org.springframework.boot" level="WARN"/>
        <logger name="org.springframework.context" level="WARN"/>

        <!-- 根日志级别 -->
        <root level="WARN">
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

    <!-- 默认配置（非dev和prod环境） -->
    <springProfile name="!dev,!prod">
        <root level="INFO">
            <appender-ref ref="CONSOLE"/>
            <appender-ref ref="FILE"/>
            <appender-ref ref="ERROR_FILE"/>
        </root>
    </springProfile>

</configuration>

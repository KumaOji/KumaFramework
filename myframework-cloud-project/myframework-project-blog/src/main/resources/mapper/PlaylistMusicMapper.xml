<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">
<mapper namespace="cn.kuma.blog.main.mapper.PlaylistMusicMapper">

    <!-- 根据播放列表ID删除所有关联 -->
    <delete id="deleteByPlaylistId">
        DELETE FROM playlist_music
        WHERE playlist_id = #{playlistId}
    </delete>

    <!-- 根据播放列表ID查询音乐ID列表（按排序顺序） -->
    <select id="selectMusicIdsByPlaylistId" resultType="java.lang.Long">
        SELECT music_id
        FROM playlist_music
        WHERE playlist_id = #{playlistId}
        ORDER BY sort_order ASC
    </select>

</mapper>

<?xml version="1.0" encoding="UTF-8"?>
<!--
    SpotBugs Exclude Filter
    https://spotbugs.readthedocs.io/en/latest/filter.html
-->
<FindBugsFilter
        xmlns="https://github.com/spotbugs/filter/3.0.0"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="https://github.com/spotbugs/filter/3.0.0 https://raw.githubusercontent.com/spotbugs/spotbugs/3.1.0/spotbugs/etc/findbugsfilter.xsd">

    <!-- 1. 排除所有测试代码 -->
    <Match>
        <Source name="~.*/src/test/.*"/>
    </Match>

    <!-- 2. 排除 Lombok / MapStruct / Protobuf / 编译生成代码 -->
    <Match>
        <Class name="~.*\$.*Builder"/>
    </Match>
    <Match>
        <Class name="~.*MapperImpl"/>
    </Match>
    <Match>
        <Source name="~.*/generated/.*"/>
    </Match>
    <Match>
        <Source name="~.*/generated-sources/.*"/>
    </Match>

    <!-- 3. Spring Boot 配置/启动类常见误报 -->
    <Match>
        <Class name="~.*Application"/>
        <Bug pattern="DM_EXIT"/>
    </Match>
    <Match>
        <Class name="~.*Configuration"/>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- 4. 实体类（DTO / VO / PO）的 getter/setter 数组引用误报 -->
    <Match>
        <Or>
            <Class name="~.*\.dto\..*"/>
            <Class name="~.*\.vo\..*"/>
            <Class name="~.*\.entity\..*"/>
            <Class name="~.*\.po\..*"/>
        </Or>
        <Bug pattern="EI_EXPOSE_REP,EI_EXPOSE_REP2"/>
    </Match>

    <!-- 5. 国际化资源、序列化字段相关的低价值告警 -->
    <Match>
        <Bug pattern="SE_NO_SERIALVERSIONID"/>
    </Match>

</FindBugsFilter>

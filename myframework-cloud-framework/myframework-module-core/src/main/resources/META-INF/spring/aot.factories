com.kuma.boot.core.runtime.aot.KmcBeanFactoryInitializationAotProcessor

org.springframework.beans.factory.aot.BeanRegistrationAotProcessor=\
com.kuma.boot.core.runtime.aot.KmcBeanRegistrationAotProcessor

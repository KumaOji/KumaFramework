				<pattern>
					<omitEmptyFields>false</omitEmptyFields>
					<pattern>
						{
						"application_name": "${APP_NAME:-}",
						"env": "${SPRING_PROFILES_ACTIVE:-}",
						"kmc_version": "${KMC_VERSION:-}",
						"server_ip": "${SERVER_IP:-}",
						"server_port": "${SERVER_PORT:-}",
						"timestamp": "%d{yyyy-MM-dd HH:mm:ss.SSS}",
						"logday": "%d{yyyy-MM-dd}",
						"thread": "%thread",
						"pid": "${PID:-}",
						"logger": "%logger{360}",
						"level": "%p",
						"method": "%M",
						"line": "%L",
						"message": "%msg",
						"full_message": "${CONSOLE_LOG_PATTERN_NO_COLOR:-}",
						"host": "${SERVER_IP:-}",
						"stack_trace": "%ex",
						"otlp_parent_span_id": "%X{X-B3-ParentSpanId:-}",
						"otlp_span_id": "%X{X-B3-SpanId:-}",
						"otlp_trace_id": "%X{X-B3-TraceId:-}",
						"otlp_span_export": "%X{X-Span-Export:-}",
						"skywalking_trace_id": "%X{tid:-}",
						"kuma_cloud_trace_id": "%X{kmc-trace-id:-}",
						"source": "kuma_cloud_sys_log"
						}
					</pattern>
				</pattern>
			</providers>
		</encoder>


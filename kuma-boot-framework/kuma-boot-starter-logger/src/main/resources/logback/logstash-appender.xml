				<provider
					class="org.apache.skywalking.apm.toolkit.log.logback.v1.x.logstash.TraceIdJsonProvider"/>

				<mdc/>
				<version>
					<fieldName>version</fieldName>
					<version>${KMC_VERSION:--}</version>
					<writeAsInteger>false</writeAsInteger>
				</version>
				<timestamp>
					<fieldName>ts</fieldName>
					<timeZone>UTC</timeZone>
				</timestamp>
				<message/>
				<rawMessage/>
				<threadName/>
				<logLevel/>
				<logLevelValue/>
				<callerData/>
				<stackTrace/>
				<rootStackTraceElement/>
				<stackHash/>
				<throwableClassName/>
				<throwableRootCauseClassName/>
				<context/>
				<!--				<contextName/>-->
				<tags/>
				<logstashMarkers/>
				<sequence/>
				<arguments>
					<includeNonStructuredArguments>true</includeNonStructuredArguments>
				</arguments>

				<!--				<callerData>-->
				<!--					<classFieldName>class</classFieldName>-->
